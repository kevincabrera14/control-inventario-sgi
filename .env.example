# .env example for Railway deployment
# Copy this to .env and fill in the values

SECRET_KEY=django-insecure-REPLACE_ME
DEBUG=False
# Comma-separated list of allowed hosts, e.g., myapp.up.railway.app
ALLOWED_HOSTS=myapp.up.railway.app
# PostgreSQL URL provided by Railway (example format)
DATABASE_URL=postgres://user:password@hostname:5432/dbname
# Port is set by Railway runtime, usually 8000, but can be overridden
PORT=8000
